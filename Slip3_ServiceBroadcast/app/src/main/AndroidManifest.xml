<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Slip3Service">

        <!-- Program 1: Background Service (Music) + Program 2: BroadcastReceiver (Airplane)
             Both programs share one MainActivity with Start/Stop Music buttons.
             AirplaneReceiver is registered dynamically at runtime (required Android 8+). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Service &amp; Broadcast">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MusicService declaration -->
        <service
            android:name=".MusicService"
            android:exported="false" />

    </application>
</manifest>
